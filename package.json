{
  "name": "org-bench",
  "version": "0.0.0",
  "private": true,
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@eslint/js": "^9.25.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.30.1",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "analyze": "npm run --workspace @org-bench/orchestrator analyze --",
    "aggregate": "npm run --workspace @org-bench/orchestrator aggregate --",
    "bench": "npm run --workspace @org-bench/orchestrator bench --",
    "build": "npm run --workspaces --if-present build",
    "format": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "npm run --workspaces --if-present typecheck"
  }
}
